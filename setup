#!/bin/bash
# setup - NeuStack one-command setup (cross-platform)
#
# Auto-detects OS and dispatches to platform-specific scripts.
# Windows users: run scripts/windows/setup.ps1 in PowerShell.
#
# Usage:
#   ./setup [command] [args...]
#   ./setup [build-options...]
#
# Commands:
#   (none)       Build the project (default)
#   build        Same as above
#   collect      Start data collection (requires sudo)
#   traffic IP   Generate traffic to server
#   fuzz         Build parser fuzz targets
#   help         Show this help
#
# Examples:
#   ./setup                        # Build
#   ./setup --with-fuzzers         # Build with parser fuzz targets
#   ./setup fuzz                   # Same as above
#   sudo ./setup collect           # Collect data
#   ./setup traffic 1.2.3.4        # Send traffic to server
#
# Cross-platform deployment:
#   ┌─────────────────────────────────────────────────────────┐
#   │  1. Linux server                                         │
#   │     scp -r NeuStack user@server:~/                      │
#   │     ssh server "cd NeuStack && sudo ./setup"            │
#   │     ssh server "cd NeuStack && sudo ./setup collect"    │
#   │                                                          │
#   │  2. Mac client                                           │
#   │     ./setup traffic SERVER_IP                           │
#   │                                                          │
#   │  3. Server: Ctrl+C to stop, check collected_data/       │
#   │                                                          │
#   │  4. Windows (PowerShell as Admin)                        │
#   │     .\scripts\windows\setup.ps1                         │
#   └─────────────────────────────────────────────────────────┘

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# 检测平台
detect_platform() {
    case "$(uname -s)" in
        Darwin*)       echo "mac" ;;
        Linux*)        echo "linux" ;;
        MINGW*|MSYS*)  echo "windows" ;;
        *)             echo "unknown" ;;
    esac
}

PLATFORM=$(detect_platform)

if [ $# -eq 0 ]; then
    COMMAND="build"
    FORWARD_ARGS=()
elif [[ "$1" == -* ]]; then
    COMMAND="build"
    FORWARD_ARGS=("$@")
else
    COMMAND="$1"
    FORWARD_ARGS=("${@:2}")
fi

# 显示帮助
show_help() {
    echo "NeuStack Setup"
    echo ""
    echo "Usage: ./setup [command] [args...]"
    echo ""
    echo "Commands:"
    echo "  build           Build NeuStack (default)"
    echo "  build           Build NeuStack (default)"
    echo "  fuzz            Build parser fuzz targets"
    echo "  collect         Start data collection (requires sudo)"
    echo "  traffic IP      Generate traffic to server"
    echo "  help            Show this help"
    echo ""
    echo "Build options:"
    echo "  --no-ai              Disable AI during setup"
    echo "  --with-fuzzers       Enable parser fuzz targets and toolchain checks"
    echo "  --with-tls           Enable TLS/HTTPS support (mbedTLS)"
    echo ""
    echo "Platform: $PLATFORM"
    echo ""
    echo "Examples:"
    echo "  ./setup                     # Build"
    echo "  ./setup --with-fuzzers      # Build fuzz targets"
    echo "  ./setup fuzz                # Build fuzz targets"
    echo "  sudo ./setup collect        # Collect data"
    echo "  ./setup traffic 1.2.3.4     # Send traffic to server"
    echo ""
    echo "Windows:"
    echo "  Run in PowerShell as Administrator:"
    echo "  .\\scripts\\windows\\setup.ps1"
}

# 主逻辑
case "$COMMAND" in
    build|"")
        echo "Platform: $PLATFORM"
        echo ""
        if [ "$PLATFORM" = "mac" ]; then
            bash scripts/mac/setup.sh "${FORWARD_ARGS[@]}"
        elif [ "$PLATFORM" = "linux" ]; then
            bash scripts/linux/setup.sh "${FORWARD_ARGS[@]}"
        elif [ "$PLATFORM" = "windows" ]; then
            echo "Windows detected (MSYS/MinGW shell)."
            echo ""
            echo "Please use PowerShell instead:"
            echo "  .\\scripts\\windows\\setup.ps1"
            echo ""
            echo "Or from this shell, try:"
            echo "  powershell -ExecutionPolicy Bypass -File scripts/windows/setup.ps1"
            exit 1
        else
            echo "ERROR: Unsupported platform: $(uname -s)"
            exit 1
        fi
        ;;

    fuzz)
        echo "Platform: $PLATFORM"
        echo ""
        if [ "$PLATFORM" = "mac" ]; then
            bash scripts/mac/setup.sh --with-fuzzers "${FORWARD_ARGS[@]}"
        elif [ "$PLATFORM" = "linux" ]; then
            bash scripts/linux/setup.sh --with-fuzzers "${FORWARD_ARGS[@]}"
        else
            echo "ERROR: fuzz setup not supported on $PLATFORM"
            exit 1
        fi
        ;;

    collect)
        shift
        if [ "$PLATFORM" = "mac" ]; then
            exec bash scripts/mac/collect.sh "$@"
        elif [ "$PLATFORM" = "linux" ]; then
            exec bash scripts/linux/collect.sh "$@"
        else
            echo "ERROR: collect not supported on $PLATFORM"
            exit 1
        fi
        ;;

    traffic)
        shift
        if [ "$PLATFORM" != "mac" ]; then
            echo "WARNING: traffic command is designed for Mac"
            echo "  (but will try to run anyway)"
        fi
        exec bash scripts/mac/traffic.sh "$@"
        ;;

    help|--help|-h)
        show_help
        ;;

    *)
        echo "Unknown command: $COMMAND"
        echo "Run './setup help' for usage"
        exit 1
        ;;
esac
