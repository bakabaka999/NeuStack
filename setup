#!/bin/bash
# setup - NeuStack 配置入口
#
# 自动检测平台并调用对应的配置脚本
#
# 用法:
#   ./setup [command]
#
# 命令:
#   (无)       编译项目
#   build      同上，编译项目
#   collect    启动数据采集
#   traffic    生成流量 (仅 Mac, 需要服务器 IP)
#   help       显示帮助
#
# 示例:
#   ./setup                        # 编译
#   sudo ./setup collect           # 采集数据
#   ./setup traffic 1.2.3.4        # 向服务器发流量
#
# 跨平台部署流程:
#   ┌─────────────────────────────────────────────────────────┐
#   │  1. Linux 服务器                                         │
#   │     scp -r NeuStack user@server:~/                      │
#   │     ssh server "cd NeuStack && sudo ./setup"            │
#   │     ssh server "cd NeuStack && sudo ./setup collect"    │
#   │                                                          │
#   │  2. Mac 客户端                                           │
#   │     ./setup traffic SERVER_IP                           │
#   │                                                          │
#   │  3. 服务器 Ctrl+C 停止, 查看 collected_data/             │
#   └─────────────────────────────────────────────────────────┘

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# 检测平台
detect_platform() {
    case "$(uname -s)" in
        Darwin*)  echo "mac";;
        Linux*)   echo "linux";;
        *)        echo "unknown";;
    esac
}

PLATFORM=$(detect_platform)
COMMAND="${1:-build}"

# 显示帮助
show_help() {
    echo "NeuStack Setup"
    echo ""
    echo "Usage: ./setup [command] [args...]"
    echo ""
    echo "Commands:"
    echo "  build           Build NeuStack (default)"
    echo "  collect         Start data collection (requires sudo)"
    echo "  traffic IP      Generate traffic to server (Mac only)"
    echo "  help            Show this help"
    echo ""
    echo "Platform: $PLATFORM"
    echo ""
    echo "Examples:"
    echo "  ./setup                     # Build"
    echo "  sudo ./setup collect        # Collect data"
    echo "  ./setup traffic 1.2.3.4     # Send traffic to server"
    echo ""
    echo "Workflow for real network data:"
    echo "  1. Copy NeuStack to Linux server"
    echo "  2. On server: sudo ./setup && sudo ./setup collect"
    echo "  3. On Mac:    ./setup traffic SERVER_IP"
    echo "  4. On server: Ctrl+C to stop, check collected_data/"
}

# 主逻辑
case "$COMMAND" in
    build|"")
        echo "Platform: $PLATFORM"
        echo ""
        if [ "$PLATFORM" = "mac" ]; then
            bash scripts/mac/setup.sh
        elif [ "$PLATFORM" = "linux" ]; then
            bash scripts/linux/setup.sh
        else
            echo "ERROR: Unsupported platform: $(uname -s)"
            exit 1
        fi
        ;;

    collect)
        if [ "$PLATFORM" = "mac" ]; then
            shift
            exec bash scripts/mac/collect.sh "$@"
        elif [ "$PLATFORM" = "linux" ]; then
            shift
            exec bash scripts/linux/collect.sh "$@"
        else
            echo "ERROR: Unsupported platform"
            exit 1
        fi
        ;;

    traffic)
        shift
        if [ "$PLATFORM" != "mac" ]; then
            echo "WARNING: traffic command is designed for Mac"
            echo "  (but will try to run anyway)"
        fi
        exec bash scripts/mac/traffic.sh "$@"
        ;;

    help|--help|-h)
        show_help
        ;;

    *)
        echo "Unknown command: $COMMAND"
        echo "Run './setup help' for usage"
        exit 1
        ;;
esac
