{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "-j", "8"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "dependsOn": ["CMake: Configure"]
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--target", "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Rebuild",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--clean-first",
                "-j", "8"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run NeuStack (sudo)",
            "type": "shell",
            "command": "sudo",
            "args": [
                "${workspaceFolder}/build/neustack"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["CMake: Build"],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "neustack: run with sudo (background)",
            "type": "shell",
            "command": "sudo",
            "args": ["${workspaceFolder}/build/examples/neustack_demo"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["CMake: Build"],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^(.*)$",
                    "file": 1,
                    "location": 1,
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "neustack: start debugserver (run this first, then F5)",
            "type": "shell",
            "command": "sudo",
            "args": [
                "/Library/Developer/CommandLineTools/Library/PrivateFrameworks/LLDB.framework/Resources/debugserver",
                "127.0.0.1:12345",
                "${workspaceFolder}/build/examples/neustack_demo"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["CMake: Build"],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "neustack: sudo lldb (terminal, CLI debug)",
            "type": "shell",
            "command": "sudo",
            "args": [
                "lldb",
                "${workspaceFolder}/build/examples/neustack_demo"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["CMake: Build"],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir", "build",
                "--output-on-failure"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "problemMatcher": []
        }
    ]
}
